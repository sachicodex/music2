<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/notification_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="10dp"
    android:paddingTop="8dp"
    android:paddingEnd="10dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:id="@+id/notification_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_notification_card"
        android:minHeight="206dp"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="16dp"
        android:paddingEnd="18dp"
        android:paddingBottom="20dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/brand_icon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@null"
                    android:src="@drawable/ic_notification_brand" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="SONIC PULSE"
                    android:textAllCaps="true"
                    android:textColor="#8EC5B3A7"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_alignParentEnd="true"
                android:contentDescription="@null"
                android:src="@android:drawable/arrow_down_float"
                android:tint="#8EC5B3A7" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/artwork"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:background="@drawable/bg_notification_art_frame"
                android:contentDescription="@null"
                android:padding="2dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_notification_art_placeholder" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="18dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="#FFF3E2D6"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/artist"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="#FFD0A88A"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/album"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:textColor="#8EC5B3A7"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/previous"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:background="@drawable/bg_notification_action_subtle"
                android:contentDescription="Previous"
                android:padding="14dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_media_previous"
                android:tint="#FFF7E4D7" />

            <ImageButton
                android:id="@+id/play_pause"
                android:layout_width="74dp"
                android:layout_height="74dp"
                android:layout_marginStart="18dp"
                android:layout_marginEnd="18dp"
                android:background="@drawable/bg_notification_action_primary"
                android:contentDescription="Play or pause"
                android:padding="18dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_media_play"
                android:tint="#FF1A0C04" />

            <ImageButton
                android:id="@+id/next"
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:background="@drawable/bg_notification_action_subtle"
                android:contentDescription="Next"
                android:padding="14dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_media_next"
                android:tint="#FFF7E4D7" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
