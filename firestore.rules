rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidUserDocument() {
      return request.resource.data.keys().hasOnly([
            'email',
            'likedSongs',
            'dislikedSongs',
            'updatedAt'
          ]) &&
          request.resource.data.email is string &&
          request.resource.data.likedSongs is list &&
          request.resource.data.dislikedSongs is list;
    }

    function isValidPlaylistDocument() {
      return request.resource.data.keys().hasOnly([
            'name',
            'songIds',
            'createdAt',
            'updatedAt'
          ]) &&
          request.resource.data.name is string &&
          request.resource.data.songIds is list;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && isValidUserDocument();
      allow delete: if isOwner(userId);

      match /playlists/{playlistId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidPlaylistDocument();
        allow delete: if isOwner(userId);
      }
    }
  }
}
